{
    "manifest_version": 3,
    "name": "File Compression Tool",
    "version": "1.0.0",
    "description": "Multi-format file compression extension — supports text, images, audio, video, and archives.",
    "permissions": [],
    "action": {
        "default_popup": "popup.html",
        "default_title": "File Compressor"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}
